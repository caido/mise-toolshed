#!/usr/bin/env sh
# Clone or update caido/ai-ops in a cache dir, then sync skills/ into agent directories (cwd).
# Copy semantics: each destination is replaced to match upstream skills (removed skills disappear locally).

set -eu

if ! command -v git >/dev/null 2>&1; then
	echo "toolshed:skills: git is required but was not found on PATH" >&2
	exit 1
fi

ROOT="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
VERSION="$(basename "$ROOT")"

REPO="${AI_OPS_SKILLS_REPO:-https://github.com/caido/ai-ops.git}"
CACHE="${AI_OPS_SKILLS_CACHE:-${XDG_CACHE_HOME:-$HOME/.cache}/mise-toolshed/ai-ops}"

# Optional: pin ref regardless of mise tool version (e.g. main, v1.0.0).
REF="${AI_OPS_SKILLS_REF:-}"

export GIT_TERMINAL_PROMPT=0

ensure_repo() {
	if [ -d "$CACHE/.git" ]; then
		return 0
	fi
	_parent="$(dirname "$CACHE")"
	mkdir -p "$_parent"
	echo "toolshed:skills: cloning $REPO into $CACHE" >&2
	git clone "$REPO" "$CACHE"
}

sync_ref() {
	_target="$1"
	if [ "$_target" = "latest" ]; then
		git -C "$CACHE" fetch origin
		if git -C "$CACHE" rev-parse --verify origin/main >/dev/null 2>&1; then
			git -C "$CACHE" checkout -B main origin/main
		elif git -C "$CACHE" rev-parse --verify origin/master >/dev/null 2>&1; then
			git -C "$CACHE" checkout -B master origin/master
		else
			echo "toolshed:skills: neither origin/main nor origin/master exists after fetch" >&2
			exit 1
		fi
		return 0
	fi

	git -C "$CACHE" fetch origin --tags --prune 2>/dev/null || git -C "$CACHE" fetch origin 2>/dev/null || true

	if git -C "$CACHE" rev-parse --verify "$_target^{commit}" >/dev/null 2>&1; then
		git -C "$CACHE" checkout "$_target"
		return 0
	fi

	echo "toolshed:skills: ref $_target not found in ai-ops, using default branch" >&2
	sync_ref latest
}

ensure_repo

if [ -n "$REF" ]; then
	sync_ref "$REF"
else
	sync_ref "$VERSION"
fi

SRC="$CACHE/skills"
if [ ! -d "$SRC" ]; then
	echo "toolshed:skills: missing $SRC after checkout (is ai-ops OK?)" >&2
	exit 1
fi

sync_one() {
	_dest="$1"
	mkdir -p "$_dest"
	if command -v rsync >/dev/null 2>&1; then
		rsync -a --delete "$SRC"/ "$_dest"/
		return
	fi
	for _d in "$SRC"/*; do
		[ -e "$_d" ] || continue
		if [ ! -d "$_d" ]; then
			continue
		fi
		_base="$(basename "$_d")"
		rm -rf "$_dest/$_base"
		cp -R "$_d" "$_dest/$_base"
	done
	if [ -d "$_dest" ]; then
		for _existing in "$_dest"/*; do
			[ -e "$_existing" ] || continue
			_base="$(basename "$_existing")"
			if [ ! -d "$SRC/$_base" ]; then
				rm -rf "$_existing"
			fi
		done
	fi
}

sync_one ".claude/skills"
sync_one ".agents/skills"
sync_one ".cursor/skills"

echo "toolshed:skills: synced from ai-ops ($SRC) to .claude/skills, .agents/skills, .cursor/skills (under $PWD)" >&2
